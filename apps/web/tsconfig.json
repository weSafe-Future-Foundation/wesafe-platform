{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@wesafe/ui": ["../../packages/ui/components"],
      "@wesafe/types": ["../../packages/types/src"],
      "@wesafe/api-client": ["../../packages/api-client/src"],
      "@wesafe/auth": ["../../packages/auth/src"],
      "@wesafe/database": ["../../libs/database/src"],
      "@wesafe/marketing": ["../../packages/marketing/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
